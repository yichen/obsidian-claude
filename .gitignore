# --- IGNORE LIST ---
# Ignore heavy/internal Obsidian noise
.obsidian/workspace
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/
.obsidian/indexed-db/
.obsidian/plugins/obsidian-git/

# Machine-specific settings
.claude/settings.local.json
.claude/settings.local.sync-conflict-*

# System files
.DS_Store
*.pyc
__pycache__/

# --- EXCEPTIONS ---
# If you want to be extra sure your AI config is tracked
!/.claude/
!/.claude/**
!/.gitignore